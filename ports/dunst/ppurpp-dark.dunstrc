[global]
    frame_color = "#98c379"

[urgency_low]
    background = "#20202a"
    foreground = "#5c6370"
    highlight = "#fb7385"

[urgency_normal]
    background = "#20202a"
    foreground = "#abb2bf"
    highlight = "#fb7385"

[urgency_critical]
    background = "#20202a"
    foreground = "#abb2bf"
    frame_color = "#ff4e4e"
    highlight = "#ff4e4e"
