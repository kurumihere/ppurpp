[global]
    frame_color = "#98c379"

[urgency_low]
    background = "#ffffff"
    foreground = "#939aa6"
    highlight = "#fb7385"

[urgency_normal]
    background = "#ffffff"
    foreground = "#383a3f"
    highlight = "#fb7385"

[urgency_critical]
    background = "#ffffff"
    foreground = "#383a3f"
    frame_color = "#ff4e4e"
    highlight = "#ff4e4e"
