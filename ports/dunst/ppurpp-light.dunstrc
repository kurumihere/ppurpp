[global]
    frame_color = "#8A62B3"

[urgency_low]
    background = "#F5F6FA"
    foreground = "#6F6B84"
    highlight = "#7A4DA3"

[urgency_normal]
    background = "#F5F6FA"
    foreground = "#20202A"
    highlight = "#7A4DA3"

[urgency_critical]
    background = "#F5F6FA"
    foreground = "#20202A"
    frame_color = "#C72C52"
    highlight = "#C72C52"

